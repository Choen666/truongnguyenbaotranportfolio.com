.hero-note span { color:var(--cobalt); }.vertical-label { position:absolute; right:24px; top:50%; writing-mode:vertical-rl; transform:rotate(180deg); font:700 10px var(--mono); letter-spacing:.12em; }
.hero-orbit { position:absolute; border:1px solid rgba(101,27,67,.35); border-radius:50%; }.orbit-one { top:-13vw; right:-20vw; width:65vw; height:65vw; }.orbit-two { top:8vw; right:-10vw; width:44vw; height:44vw; border-style:dotted; animation:spin 50s linear infinite; }
.floating-symbol { position:absolute; z-index:2; color:var(--wine); font-family:var(--serif); opacity:.75; }.scale-symbol { top:29%; right:23vw; font-size:60px; animation:float 6s ease-in-out infinite; }.globe-symbol { right:10vw; bottom:20%; color:var(--cobalt); font-size:80px; animation:float 8s ease-in-out infinite reverse; }
.about { position:relative; display:grid; grid-template-columns:1fr 2fr 1.1fr; gap:5vw; padding-top:150px; padding-bottom:135px; }.section-index { margin-top:24px; color:var(--coral); font:italic 17px var(--serif); }.about-copy { max-width:620px; }.about h2,.experience h2,.research h2,.capabilities h2,.contact h2 { margin:0 0 30px; font:600 clamp(42px,5.2vw,78px)/.98 var(--serif); letter-spacing:-.06em; }.about-copy .lead { margin-bottom:22px; font:600 20px/1.55 var(--serif); }.about-copy>p:last-child { max-width:470px; color:#654d58; }.portrait-card { align-self:center; }.portrait-frame { padding:10px; aspect-ratio:3/4; background:var(--cobalt); box-shadow:18px 19px 0 var(--coral); transform:rotate(3deg); }.portrait-frame img { width:100%; height:100%; object-fit:cover; }.portrait-card p,.portrait-card span { font:700 11px var(--mono); letter-spacing:.06em; }.portrait-card p { margin:28px 0 2px; }.portrait-card span { color:var(--cobalt); }.stats { display:grid; grid-column:2/4; grid-template-columns:repeat(3,1fr); margin-top:27px; padding-top:25px; border-top:3px solid var(--ink); }.stats div { display:flex; align-items:center; gap:12px; }.stats strong { color:var(--coral); font:600 54px/.8 var(--serif); letter-spacing:-.06em; }.stats span { font:800 10px/1.5 var(--mono); text-transform:uppercase; }
.experience { padding-top:130px; padding-bottom:135px; color:#fff8ef; background:linear-gradient(135deg,var(--plum),var(--wine) 65%,#8d2756); }.experience .section-index { color:#f8c857; }.experience-heading { display:flex; align-items:flex-end; justify-content:space-between; margin:-77px 0 76px 25.5%; }.experience-heading p { max-width:295px; margin:0; color:#f8d8d9; font-weight:600; }.experience-list { border-top:2px solid rgba(255,255,255,.35); }.experience-item { display:grid; grid-template-columns:.3fr 1.2fr 1fr 30px; gap:24px; padding:31px 0 27px; border-bottom:1px solid rgba(255,255,255,.35); transition:.35s; }.experience-item:hover { padding-left:18px; background:rgba(255,255,255,.08); }.exp-no,.period { color:#ffd56b; }.period { font-size:12px; letter-spacing:.05em; }.period i { width:6px; height:6px; margin:0 6px; background:#ff9a83; }.experience h3 { margin:5px 0 4px; font:600 23px var(--serif); }.experience h4 { margin:0; color:#f9c7d0; font:800 11px var(--mono); }.exp-description { margin:4px 0 0; color:#fff0eb; font-size:13px; }.exp-arrow { color:#ffd56b; font-size:27px; }
.research { padding-top:135px; padding-bottom:135px; background:linear-gradient(130deg,#fbe5d9,#f8dbe2 48%,#e2d9fa); }.research-top { display:grid; grid-template-columns:1fr 2.15fr; }.research-top h2 { margin-top:-20px; }.research-grid { display:grid; grid-template-columns:1fr 1fr; gap:18px; margin-top:70px; }.research-card { display:flex; flex-direction:column; min-height:395px; padding:28px; border:2px solid var(--ink); background:#fffaf3; box-shadow:8px 9px 0 var(--gold); transition:.3s; }.research-card:hover { box-shadow:14px 17px 0 var(--coral); transform:translate(-4px,-6px); }.research-card.featured { border-color:var(--cobalt); color:white; background:var(--cobalt); box-shadow:8px 9px 0 var(--coral); }.research-card .card-type { color:var(--wine); }.research-card.featured .card-type,.featured footer { color:#ffe279; }.card-type b { margin:5px 0 0; border-radius:5px; background:var(--coral); }.card-mark { margin:28px 0 15px; color:var(--coral); font:600 64px/1 var(--serif); }.featured .card-mark { color:#ffd45c; }.research-card h3 { margin:0 0 16px; font:600 28px/1.15 var(--serif); letter-spacing:-.035em; }.research-card>p { max-width:370px; margin:0; font-size:13px; }.research-card footer { display:flex; justify-content:space-between; margin-top:auto; padding-top:26px; color:var(--wine); font:800 10px var(--mono); letter-spacing:.05em; text-transform:uppercase; }.research-card.wide { display:grid; grid-column:span 2; grid-template-columns:1fr 1.3fr; min-height:300px; background:#ffcf6b; }.research-card.wide .card-mark { color:var(--cobalt); }
.capabilities { position:relative; padding-top:130px; padding-bottom:140px; }.capabilities::before { content:""; position:absolute; z-index:-1; top:8%; right:-16vw; width:36vw; height:36vw; border-radius:50%; background:#e9ddff; }.capabilities>h2 { margin:-76px 0 80px 25.5%; }.skills-cloud { display:flex; flex-wrap:wrap; align-items:center; justify-content:center; gap:13px 16px; max-width:950px; margin:auto; }.skills-cloud span { padding:12px 17px; border:2px solid var(--ink); border-radius:50px; background:#fffefa; font:800 11px var(--mono); transition:.25s; }.skills-cloud span:hover { color:white; background:var(--cobalt); transform:scale(1.08) rotate(-2deg); }.skills-cloud .large { padding:16px 23px; background:#fde0d4; font:600 20px var(--serif); }.skills-cloud .gold { border-color:var(--gold); background:#ffe08a; }.skills-cloud .pink { background:#f5a1b3; }.certificates { max-width:850px; margin:110px auto 0; padding-top:25px; border-top:3px solid var(--ink); }.certificates ul { margin:25px 0 0; padding:0; list-style:none; }.certificates li { display:grid; grid-template-columns:50px 1fr auto; gap:12px; padding:14px 0; border-bottom:1px solid var(--line); font:600 15px var(--serif); }.certificates li span,.certificates em { color:var(--cobalt); font:800 11px var(--mono); font-style:normal; }
.contact { position:relative; min-height:85vh; overflow:hidden; padding-top:130px; padding-bottom:35px; color:#fff9f2; background:linear-gradient(135deg,#240c25,#4c1644 55%,#1e3a91); }.contact-glow { position:absolute; top:-25vw; right:-14vw; width:65vw; height:65vw; border-radius:50%; opacity:.9; filter:blur(3px); background:conic-gradient(var(--coral),#f7ce53,var(--violet),var(--coral)); animation:spin 28s linear infinite; }.contact-glow::after { content:""; position:absolute; inset:22%; border-radius:50%; background:#4c1644; }.contact h2,.contact .eyebrow,.contact-copy,.email-link,.contact-footer { position:relative; z-index:1; }.contact h2 { margin:35px 0 30px; font-size:clamp(54px,8vw,120px); }.contact h2 em { color:#ffcc63; }.contact-copy { max-width:400px; margin-bottom:42px; color:#f8dce5; font-weight:600; }.email-link { display:inline-block; padding-bottom:10px; border-bottom:3px solid #ffcc63; color:white; text-decoration:none; font:600 clamp(18px,2.3vw,32px) var(--serif); }.email-link span { color:#ffcc63; }.contact-footer { position:absolute; inset:auto 9vw 27px; display:flex; justify-content:space-between; font:800 10px var(--mono); letter-spacing:.08em; text-transform:uppercase; }.contact-footer p { margin:0; }.contact-footer a { color:white; text-decoration:none; }
.reveal { opacity:0; transform:translateY(26px); transition:opacity .7s ease,transform .7s ease; }.reveal.visible { opacity:1; transform:none; }
@keyframes float { 50% { transform:translateY(-20px) rotate(8deg); } } @keyframes spin { to { transform:rotate(360deg); } } @keyframes ribbon { 50% { transform:rotate(-12deg) translateY(30px); } }
@media(max-width:800px) { .site-header{padding:0 6vw} nav{display:none} .section-pad{padding-left:6vw;padding-right:6vw} .hero{min-height:720px} .hero-sun{width:82vw;height:82vw;right:-12vw;top:19%} .hero-ribbon{top:58%} .hero-note,.vertical-label{display:none} .hero-content{margin-top:35px} .orbit-one{width:120vw;height:120vw;right:-60vw} .orbit-two{width:95vw;height:95vw;right:-48vw;top:16vw} .scale-symbol{right:15vw;top:17%} .globe-symbol{right:8vw;bottom:15%} .about{display:block;padding-top:85px;padding-bottom:85px} .section-intro{margin-bottom:45px} .section-index{margin-top:10px} .portrait-card{width:62%;margin:55px 0 50px auto} .stats{grid-template-columns:1fr 1fr;gap:26px;margin-top:0} .stats div:last-child{grid-column:span 2} .experience,.research,.capabilities{padding-top:85px;padding-bottom:85px} .experience-heading{display:block;margin:0 0 45px} .experience-heading p{margin-top:20px} .experience-item{grid-template-columns:26px 1fr 18px;gap:12px;padding:25px 0} .exp-description{grid-column:2/4;margin-top:4px} .research-top{display:block} .research-grid{grid-template-columns:1fr;margin-top:42px} .research-card{min-height:340px} .research-card.wide{display:block;grid-column:span 1;min-height:400px} .capabilities>h2{margin:0 0 45px} .certificates{margin-top:70px} .certificates li{grid-template-columns:30px 1fr} .certificates em{grid-column:2} .contact{min-height:690px;padding-top:85px} .contact-footer{left:6vw;right:6vw} .email-link{font-size:18px;word-break:break-all} }
