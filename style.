/* Pastel bunny cursor and animated moonlit footer */
.mascot-cursor { width:48px; height:54px; }.bunny { position:relative; width:48px; height:54px; transform-origin:50% 90%; }.bunny-ear { position:absolute; z-index:1; top:0; width:12px; height:25px; border:2px solid #66334d; border-radius:80% 80% 55% 55%; background:#fff9f4; transform-origin:50% 100%; }.bunny-ear::after { content:""; position:absolute; inset:4px 3px; border-radius:80%; background:#f5a9bb; }.bunny-ear.left { left:11px; transform:rotate(-16deg); }.bunny-ear.right { right:11px; transform:rotate(16deg); }.bunny-head { position:absolute; z-index:2; top:15px; left:8px; width:32px; height:28px; border:2px solid #66334d; border-radius:48% 48% 45% 45%; background:#fff9f4; }.bunny-eye { position:absolute; z-index:3; top:12px; width:3px; height:4px; border-radius:50%; background:#563046; }.bunny-eye.left { left:9px; }.bunny-eye.right { right:9px; }.bunny-glasses { position:absolute; z-index:4; left:4px; top:7px; width:21px; height:10px; border-top:1.5px solid #66334d; }.bunny-glasses::before,.bunny-glasses::after { content:""; position:absolute; width:9px; height:8px; border:1.5px solid #66334d; border-radius:50%; }.bunny-glasses::before { left:0; }.bunny-glasses::after { right:0; }.bunny-nose { position:absolute; left:14px; top:18px; width:4px; height:3px; border-radius:50% 50% 60% 60%; background:#ee8099; }.bunny-nose::after { content:"⌣"; position:absolute; left:-2px; top:-5px; color:#66334d; font:9px Georgia,serif; }.bunny-body { position:absolute; z-index:2; left:9px; top:39px; width:30px; height:16px; border:2px solid #66334d; border-radius:13px 13px 6px 6px; background:#f3a6ba; }.bunny-paw { position:absolute; z-index:3; top:2px; width:10px; height:10px; border:2px solid #66334d; border-radius:50%; background:#fff9f4; transform-origin:50% 20%; }.bunny-paw.left { left:-7px; }.bunny-paw.right { right:-7px; }.bunny-book { position:absolute; z-index:4; right:-10px; top:0; width:19px; height:14px; border:1.5px solid #66334d; border-radius:2px; background:#6a2047; box-shadow:inset 3px 0 #f2c95a; transform:rotate(-11deg); }.bunny-book::after { content:"§"; position:absolute; left:8px; top:1px; color:#f7d56b; font:700 7px Georgia,serif; }.bunny-book i { position:absolute; left:5px; height:100%; border-left:1px solid rgba(255,255,255,.65); }.bunny-stars { position:absolute; z-index:6; top:-9px; right:-15px; color:#ffd86a; font:800 11px var(--serif); letter-spacing:1px; opacity:0; }.mascot-cursor.moving .bunny { animation:bunny-run .22s ease-in-out infinite alternate; }.mascot-cursor.waving .bunny-paw.right { animation:bunny-wave .35s ease-in-out infinite alternate; }.mascot-cursor.hugging .bunny { transform:scale(1.1) translateX(4px); }.mascot-cursor.hugging .bunny-paw.left { animation:bunny-hug-left .38s ease-in-out infinite alternate; }.mascot-cursor.hugging .bunny-paw.right { animation:bunny-hug-right .38s ease-in-out infinite alternate; }.mascot-cursor.clicking .bunny-stars { opacity:1; animation:bunny-stars .55s ease-out; }.mascot-cursor.sleeping .bunny { transform:rotate(15deg) translateY(7px); }.mascot-cursor.sleeping::after { content:"z z"; position:absolute; top:-5px; left:35px; color:var(--cobalt); font:800 10px var(--mono); animation:sleep-float 1.5s ease-in-out infinite; }.mascot-cursor.blinking .bunny-eye { height:1px; top:14px; }.mascot-cursor.idle .bunny-ear.left { animation:bunny-ear-left 1.6s ease-in-out infinite; }.mascot-cursor.idle .bunny-ear.right { animation:bunny-ear-right 1.6s ease-in-out infinite; }.mascot-cursor.idle .bunny { animation:bunny-breathe 2.4s ease-in-out infinite; }
@keyframes bunny-run { to { transform:translateY(-5px) rotate(-4deg); } } @keyframes bunny-wave { to { transform:rotate(-85deg); } } @keyframes bunny-hug-left { to { transform:translate(11px,2px) rotate(-45deg); } } @keyframes bunny-hug-right { to { transform:translate(-11px,2px) rotate(45deg); } } @keyframes bunny-stars { to { transform:translate(9px,-16px) rotate(25deg); opacity:0; } } @keyframes bunny-ear-left { 50% { transform:rotate(-28deg); } } @keyframes bunny-ear-right { 50% { transform:rotate(28deg); } } @keyframes bunny-breathe { 50% { transform:scale(1.035) translateY(-1px); } }
.night-sky { position:absolute; z-index:1; inset:0; overflow:hidden; pointer-events:none; }.sky-star { position:absolute; color:#fff2aa; text-shadow:0 0 11px #f8ce6c; font-size:14px; animation:twinkle 2.5s ease-in-out infinite alternate; }.s1 { top:15%; left:44%; }.s2 { top:30%; left:79%; animation-delay:.7s; }.s3 { top:64%; left:63%; animation-delay:1.3s; }.s4 { top:19%; left:91%; animation-delay:1.8s; }.s5 { top:79%; left:82%; animation-delay:.3s; }.petal { position:absolute; color:#f9a4c0; opacity:.8; font-size:15px; animation:petal-fall 10s linear infinite; }.p1 { left:69%; top:-5%; }.p2 { left:89%; top:9%; animation-delay:2.4s; }.p3 { left:55%; top:12%; animation-delay:5s; }.p4 { left:95%; top:42%; animation-delay:7s; }.moon-reader { position:absolute; right:8vw; bottom:25px; width:175px; height:135px; }.moon { position:absolute; right:10px; bottom:0; width:108px; height:108px; border-radius:50%; background:#ffe89b; box-shadow:0 0 30px rgba(255,218,114,.65); }.moon::after { content:""; position:absolute; top:-15px; left:-19px; width:108px; height:108px; border-radius:50%; background:#3d1642; }.footer-bunny { position:absolute; z-index:2; bottom:35px; right:57px; width:42px; height:46px; border:2px solid #fff6ef; border-radius:48% 48% 43% 43%; background:#f3a6ba; }.footer-bunny::before,.footer-bunny::after { content:""; position:absolute; top:-25px; width:11px; height:28px; border:2px solid #fff6ef; border-radius:80% 80% 50% 50%; background:#f9d3dc; }.footer-bunny::before { left:7px; transform:rotate(-12deg); }.footer-bunny::after { right:7px; transform:rotate(12deg); }.footer-bunny span { position:absolute; z-index:2; top:13px; width:3px; height:3px; border-radius:50%; background:#4a2644; }.footer-bunny span:first-child { left:12px; }.footer-bunny span:nth-child(2) { right:12px; }.footer-bunny i { position:absolute; z-index:3; right:-10px; bottom:-3px; width:24px; height:18px; border:1px solid #f8dc87; border-radius:2px; background:#6a2047; transform:rotate(-12deg); }.footer-bunny b { position:absolute; z-index:4; right:-1px; bottom:2px; color:#f8dc87; font:700 9px Georgia,serif; }@keyframes twinkle { to { transform:scale(1.5); opacity:.35; } } @keyframes petal-fall { to { transform:translate(-55px,105vh) rotate(330deg); opacity:0; } }
@media(max-width:800px) { .moon-reader { right:4vw; transform:scale(.68); transform-origin:bottom right; }.sky-star.s1,.sky-star.s3,.petal.p3 { display:none; } }
