h1,h2,h3,h4,p { margin-top:0; }
h1 { margin:0; font:600 clamp(63px,10.5vw,150px)/.84 var(--serif); letter-spacing:-.075em; text-shadow:1px 2px 0 rgba(255,255,255,.6); }
h1 em,h2 em { color:var(--wine); font-weight:500; }
.hero-bottom { display:flex; align-items:center; gap:42px; margin:52px 0 0 8px; }
.hero-bottom p { margin:0; font:700 13px/1.55 var(--mono); }
.circle-link { display:grid; place-items:center; width:57px; height:57px; border-radius:50%; color:white; background:var(--ink); box-shadow:8px 9px 0 var(--gold); text-decoration:none; font-size:26px; transition:.3s; }
