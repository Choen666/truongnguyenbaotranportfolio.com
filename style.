.header-tools { display:flex; align-items:center; gap:12px; }
.language-switcher { display:flex; gap:2px; padding:3px; border:1px solid rgba(36,12,37,.17); border-radius:22px; background:rgba(255,255,255,.55); }
.language-switcher button { width:28px; height:26px; padding:0; border:0; border-radius:16px; color:var(--ink); background:transparent; cursor:pointer; font:800 10px var(--mono); transition:.25s; }
.language-switcher button.active { color:#fff; background:var(--wine); box-shadow:0 2px 6px rgba(101,27,67,.25); }
