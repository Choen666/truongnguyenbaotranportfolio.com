/* Mini legal researcher cursor mascot */
@media (pointer:fine) {
  body, body a, body button { cursor:none; }
}
.mascot-cursor { position:fixed; z-index:50; left:0; top:0; width:50px; height:56px; pointer-events:none; opacity:0; transform:translate(-70px,-70px); transition:opacity .25s; }
.mascot-cursor.ready { opacity:1; }.mascot { position:relative; width:50px; height:56px; transform-origin:50% 90%; }.mascot-head { position:absolute; z-index:3; left:12px; top:4px; width:27px; height:27px; border:2px solid #4b1c38; border-radius:48% 48% 46% 46%; background:#ffe6d3; }.mascot-hair { position:absolute; left:-2px; top:-5px; width:29px; height:15px; border:3px solid #4b1c38; border-bottom:0; border-radius:55% 55% 20% 20%; background:#432039; }.mascot-hair::after { content:""; position:absolute; top:7px; right:-5px; width:9px; height:18px; border:2px solid #4b1c38; border-radius:0 9px 9px 0; background:#432039; }.mascot-ear { position:absolute; top:12px; width:5px; height:7px; border:1px solid #4b1c38; border-radius:50%; background:#ffe6d3; }.mascot-ear.left { left:-5px; }.mascot-ear.right { right:-5px; }.mascot-eye { position:absolute; z-index:3; top:13px; width:3px; height:3px; border-radius:50%; background:#4b1c38; }.mascot-eye.left { left:7px; }.mascot-eye.right { right:7px; }.mascot-glasses { position:absolute; z-index:4; left:3px; top:9px; width:19px; height:10px; border-top:1.6px solid #4b1c38; }.mascot-glasses::before,.mascot-glasses::after { content:""; position:absolute; top:0; width:8px; height:7px; border:1.6px solid #4b1c38; border-radius:50%; }.mascot-glasses::before { left:0; }.mascot-glasses::after { right:0; }.mascot-smile { position:absolute; left:11px; top:20px; width:6px; height:3px; border-bottom:1.5px solid #c65e74; border-radius:0 0 50% 50%; }.mascot-body { position:absolute; z-index:2; left:9px; top:29px; width:31px; height:24px; border:2px solid #4b1c38; border-radius:11px 11px 6px 6px; background:#f39eb5; }.mascot-shirt { position:absolute; left:10px; top:0; width:8px; height:13px; border:1px solid #4b1c38; border-top:0; background:#fff; clip-path:polygon(0 0,100% 0,78% 100%,50% 76%,22% 100%); }.mascot-arm { position:absolute; top:4px; width:10px; height:17px; border:2px solid #4b1c38; border-radius:8px; background:#f39eb5; transform-origin:top center; }.mascot-arm.left { left:-7px; transform:rotate(25deg); }.mascot-arm.right { right:-7px; transform:rotate(-25deg); }.mascot-book { position:absolute; z-index:5; right:-11px; top:8px; width:18px; height:14px; border:1.5px solid #4b1c38; border-radius:2px; background:#6a2047; box-shadow:inset 3px 0 #f2c95a; transform:rotate(-10deg); }.mascot-book::after { content:"§"; position:absolute; left:7px; top:1px; color:#f7d56b; font:700 7px Georgia,serif; }.mascot-book i { position:absolute; left:5px; top:0; height:100%; border-left:1px solid rgba(255,255,255,.65); }.mascot-note { position:absolute; z-index:6; right:-13px; top:5px; color:#f2c95a; font-size:10px; opacity:0; }.mascot-cursor.moving .mascot { animation:mascot-bounce .38s ease-in-out infinite alternate; }.mascot-cursor.waving .mascot-arm.right { animation:mascot-wave .4s ease-in-out infinite alternate; }.mascot-cursor.reading .mascot-book { width:25px; height:15px; background:linear-gradient(90deg,#fff8e9 49%,#f3deb9 50%); transform:rotate(-4deg); }.mascot-cursor.reading .mascot-book::after { content:"⚖"; left:9px; top:2px; color:#6a2047; font-size:8px; }.mascot-cursor.writing .mascot-note { opacity:1; animation:note-write .45s ease-in-out infinite alternate; }.mascot-cursor.writing .mascot-arm.right { animation:mascot-write .38s ease-in-out infinite alternate; }.mascot-cursor.sleeping .mascot { transform:rotate(18deg) translateY(8px); }.mascot-cursor.sleeping .mascot-eye { height:1px; top:14px; border-radius:0; }.mascot-cursor.sleeping::after { content:"z z"; position:absolute; left:37px; top:-2px; color:var(--cobalt); font:800 10px var(--mono); letter-spacing:1px; animation:sleep-float 1.5s ease-in-out infinite; }.mascot-cursor.blinking .mascot-eye { height:1px; top:14px; border-radius:0; }.mascot-cursor.reading .mascot,.mascot-cursor.writing .mascot { transform:translateY(-2px); }
@keyframes mascot-bounce { to { transform:translateY(-4px) rotate(-2deg); } } @keyframes mascot-wave { to { transform:rotate(-75deg); } } @keyframes mascot-write { to { transform:rotate(-48deg) translateY(2px); } } @keyframes note-write { to { transform:translate(4px,-5px) rotate(20deg); } } @keyframes sleep-float { 50% { transform:translate(4px,-8px); opacity:.55; } }
@media (pointer:coarse) { .mascot-cursor { display:none; } }

