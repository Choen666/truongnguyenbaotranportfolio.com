.hero { position:relative; display:flex; align-items:center; min-height:100vh; overflow:hidden; background:radial-gradient(circle at 75% 20%,#ffc7b3 0,rgba(255,199,179,.7) 13%,transparent 30%),radial-gradient(circle at 80% 80%,#d5c5ff 0,rgba(213,197,255,.55) 14%,transparent 30%),linear-gradient(127deg,#fffdf7,#f9e1dd 44%,#f0c6d0); }
.hero-grid { position:absolute; inset:0; opacity:.75; background-image:linear-gradient(rgba(101,27,67,.11) 1px,transparent 1px),linear-gradient(90deg,rgba(101,27,67,.11) 1px,transparent 1px); background-size:80px 80px; mask-image:linear-gradient(to bottom,transparent,#000 25%,transparent 90%); }
.hero-sun { position:absolute; right:8vw; top:18%; width:42vw; height:42vw; border-radius:50%; opacity:.9; filter:blur(1px); background:conic-gradient(from 20deg,var(--gold),#f9d875,var(--coral),var(--rose),var(--violet),var(--gold)); animation:spin 35s linear infinite; }
.hero-sun::after { content:""; position:absolute; inset:17%; border-radius:50%; background:#f9dbd8; }
.hero-ribbon { position:absolute; top:50%; right:-23vw; width:105vw; height:150px; opacity:.8; filter:blur(1px); transform:rotate(-18deg); background:linear-gradient(90deg,transparent 2%,var(--cobalt) 30%,var(--violet) 64%,var(--coral)); animation:ribbon 10s ease-in-out infinite; }
.hero-content { position:relative; z-index:2; margin-top:68px; }
